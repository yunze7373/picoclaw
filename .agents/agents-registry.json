{
  "version": "1.0.0",
  "description": "Agent registry for dynamic discovery and routing",
  "agents": [
    {
      "id": "agent-orchestrator",
      "name": "Agent Orchestrator",
      "file": "agent-orchestrator.md",
      "model": "opus",
      "category": "orchestration",
      "description": "Primary routing layer for software engineering requests. Determines intent, selects expert agents, and coordinates workflows.",
      "triggers": [
        "multi-step",
        "pipeline",
        "parallel",
        "coordinate",
        "workflow"
      ],
      "tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep", "LS"],
      "executionModes": ["SINGLE", "PIPELINE", "PARALLEL_WORKTREE", "ARCHITECTURE", "INCIDENT"],
      "pipelines": {
        "large_project": ["parallel_worktrees", "staff-code-reviewer", "semantic-commit-generator"],
        "code_quality": ["staff-code-reviewer", "principal-refactoring-engineer", "software-test-engineer", "semantic-commit-generator"],
        "new_feature": ["principal-architect", "senior-ui-ux-designer", "implement", "software-test-engineer", "technical-documentation-engineer", "semantic-commit-generator"],

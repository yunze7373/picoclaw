      "model": "inherit",
      "category": "memory",
      "description": "Manage memory context, identity policy, and cross-session state.",
      "triggers": [
        "memory",
        "context",
        "identity",
        "cross-session",
        "state"
      ],
      "tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep", "LS"],
      "identityFields": ["source_identity", "owner_identity", "metadata"],
      "rules": [
        "Identity authority from top-level source_identity and owner_identity",
        "metadata not authoritative for identity decisions",
        "Top-level fields win over metadata conflicts",
        "path is the upsert key",
        "Explicit identity filtering when needed"
      ]
    },

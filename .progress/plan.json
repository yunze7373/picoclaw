    "agent_assignment": "每个任务必须指定 agent 和 pipeline，引用 agents-registry.json 中的 ID",
    "验证": "生成计划后必须检查：1. INBOX 检查点 2. phase_r_trigger 3. 每个任务有 agent"
  },

  "🤖 Agents 路由配置": {
    "registry": "agents-registry.json",
    "orchestrator": "agent-orchestrator",
    "pipelines": {
      "new_feature": ["principal-architect", "senior-ui-ux-designer", "implement", "software-test-engineer", "technical-documentation-engineer", "semantic-commit-generator"],
      "code_quality": ["staff-code-reviewer", "principal-refactoring-engineer", "software-test-engineer", "semantic-commit-generator"],
      "incident": ["root-cause-debugging-engineer", "fix", "software-test-engineer", "semantic-commit-generator"],
      "phase_r_review": ["staff-code-reviewer", "principal-architect", "software-test-engineer", "technical-documentation-engineer"],
      "ui_redesign": ["senior-ui-ux-designer", "implement", "staff-code-reviewer", "semantic-commit-generator"]
    },
    "task_type_mapping": {
      "architecture": "principal-architect",
      "ui-design": "senior-ui-ux-designer",
      "implementation": "agent-orchestrator → auto-select",
      "bugfix": "root-cause-debugging-engineer",
      "refactor": "principal-refactoring-engineer",
      "test": "software-test-engineer",
      "review": "staff-code-reviewer",
      "docs": "technical-documentation-engineer",
      "performance": "principal-performance-engineer"
    },
    "auto_pipeline": {
      "every_task_completion": "semantic-commit-generator",
      "phase_r": "phase_r_review"
    }
  },

  "tasks": [
    {
      "id": "task_001",
      "name": "任务名称",
      "description": "详细描述",

{
  "plan": {
    "id": "plan_001",
    "name": "{阶段名称}",
    "phase": "Phase X",
    "sprint": 1,
    "started_at": "{日期}",
    "target_end": "{日期}",
    "status": "pending",
    "created_from_report": "report_001"
  },
  "objectives": [
    "目标 1",
    "目标 2"
  ],

  "⭐ 计划生成规则": {
    "inbox_checkpoint": "每 3-5 个任务之间必须插入一个 📬 INBOX 检查点任务",

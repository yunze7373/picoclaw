      "priority": "high|medium|low",
      "status": "pending",
      "agent": "agent-orchestrator",
      "pipeline": "new_feature|code_quality|incident|null",
      "estimated_hours": 2,
      "dependencies": [],
      "deliverables": ["文件路径"],
      "definition_of_done": ["完成标准 1", "完成标准 2"],
